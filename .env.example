SKYBASE_DB_ENDPOINT=http://127.0.0.1:8080
SKYBASE_DB_AUTH_TOKEN=replace-with-local-libsql-token
# SKYBASE_DB_TOKEN is accepted as a legacy alias.
SKYBASE_DB_NAMESPACE=local
BETTER_AUTH_SECRET=replace-with-a-local-secret
BETTER_AUTH_URL=http://localhost:3100/api/auth
ALLOWED_ORIGINS=http://localhost:3100
VITE_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
SKYWORK_GATEWAY_BASE_URL=https://gateway.example.com
SKYWORK_API_TOKEN=replace-with-website-api-token
