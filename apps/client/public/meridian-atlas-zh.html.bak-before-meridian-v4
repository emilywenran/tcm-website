/* ══════════════════════════════════════════════
   STATE
══════════════════════════════════════════════ */
let currentView = 'front';  // 'front' | 'back'
let showMer = true;
let showAcu = true;
let selMid = null;
let selPt  = null;

/* ══════════════════════════════════════════════
   VIEW SWITCH — front / back
══════════════════════════════════════════════ */
function switchView(v){
  currentView = v;
  // outline
  document.getElementById('outlineFront').style.display = v==='front'?'':'none';
  document.getElementById('outlineBack').style.display  = v==='back' ?'':'none';
  // toggle buttons
  document.querySelectorAll('#viewToggle button').forEach((b,i)=>{
    b.classList.toggle('active',(i===0&&v==='front')||(i===1&&v==='back'));
  });
  // meridian paths: show paths matching current view OR 'both'
  document.querySelectorAll('.mp').forEach(p=>{
    const pv = p.dataset.view||'front';
    p.style.display = (pv==='both'||pv===v)?'':'none';
  });
  // acupoints: show only matching view
  document.querySelectorAll('.ap').forEach(a=>{
    const av = a.dataset.view||'front';
    const visible = av === v;
    // also hide if showAcu is off
    a.style.display = (visible && showAcu) ? '' : 'none';
  });
  // reapply dim/highlight
  applyHighlight();
}

/* ══════════════════════════════════════════════
   LAYER TOGGLES
══════════════════════════════════════════════ */
function toggleLayer(layer){
  if(layer==='mer'){
    showMer = !showMer;
    document.getElementById('lbtn-mer').classList.toggle('on', showMer);
    document.getElementById('meridianLayer').style.display = showMer?'':'none';
  } else {
    showAcu = !showAcu;
    document.getElementById('lbtn-acu').classList.toggle('on', showAcu);
    // hide/show only current-view points
    document.querySelectorAll('.ap').forEach(a=>{
      const av = a.dataset.view||'front';
      a.style.display = (showAcu && av===currentView)?'':'none';
    });
  }
}

/* ══════════════════════════════════════════════
   HIGHLIGHT
══════════════════════════════════════════════ */
function applyHighlight(){
  const allPaths = document.querySelectorAll('.mp');
  const allAp    = document.querySelectorAll('.ap');
  if(!selMid && !selPt){
    allPaths.forEach(p=>p.classList.remove('dim','hi'));
    allAp.forEach(a=>a.classList.remove('dim','sel'));
    return;
  }
  // dim all visible paths
  allPaths.forEach(p=>{
    const pv = p.dataset.view||'front';
    if(pv!=='both'&&pv!==currentView) return;
    if(selMid){
      p.classList.toggle('dim', p.dataset.mid !== selMid);
      p.classList.toggle('hi',  p.dataset.mid === selMid);
    } else {
      // point selected — highlight that meridian only
      const ap = ACUPOINTS[selPt];
      const mid = ap ? ap.meridian : null;
      p.classList.toggle('dim', p.dataset.mid !== mid);
      p.classList.toggle('hi',  p.dataset.mid === mid);
    }
  });
  // dim all visible ap
  allAp.forEach(a=>{
    const av = a.dataset.view||'front';
    if(av!==currentView) return;
    if(selMid){
      a.classList.toggle('dim', a.dataset.mid !== selMid);
      a.classList.remove('sel');
    } else {
      a.classList.remove('dim');
      a.classList.toggle('sel', a.dataset.pt === selPt);
    }
  });
}

function clearHighlight(){
  document.querySelectorAll('.mp').forEach(p=>p.classList.remove('dim','hi'));
  document.querySelectorAll('.ap').forEach(a=>a.classList.remove('dim','sel'));
}

