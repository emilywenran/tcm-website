  // symptoms
  const st = document.getElementById('detailSymptoms');
  st.innerHTML=d.symptoms.map(s=>`<span class="tag warn">${s}</span>`).join('');
  // massage
  const ms = document.getElementById('detailMassage');
  ms.innerHTML=d.massage.map((m,i)=>`<div class="step"><span class="snum">${i+1}</span><span>${m}</span></div>`).join('');
  // time
  document.getElementById('btClock').textContent=d.time.split(' ')[0];
  document.getElementById('btTxt').innerHTML=`最佳养护时辰<br><b>${d.time}</b>`;
  // foods
  const fd = document.getElementById('detailFoods');
  fd.innerHTML=d.foods.map(f=>`<div class="food"><span class="fdot"></span>${f}</div>`).join('');
}

function showAcupointDetail(pk){
  const d = ACUPOINTS[pk]; if(!d) return;
  const m = MERIDIANS[d.meridian]||{};
  document.getElementById('detailEmpty').style.display='none';
  const panel = document.getElementById('detailPanel');
  panel.classList.add('show');
  document.getElementById('detailBadge').className='r-badge acu';
  document.getElementById('detailBadge').textContent='穴位 · '+pk;
  document.getElementById('detailName').textContent=d.name;
  document.getElementById('detailNameEn').textContent=(m.name||'')+' · '+d.loc;
  document.getElementById('detailCbar').style.background=m.color||'#C94040';
  document.getElementById('lblFunc').textContent='主治功效';
  document.getElementById('detailFunc').textContent=d.func;
  // symptoms — show meridian symptoms as context
  const st = document.getElementById('detailSymptoms');
  const msyms = m.symptoms||[];
  st.innerHTML=`<span class="tag">定位：${d.loc}</span>`+msyms.slice(0,4).map(s=>`<span class="tag warn">${s}</span>`).join('');
  // massage
  const ms = document.getElementById('detailMassage');
  ms.innerHTML=`<div class="step"><span class="snum">✦</span><span>${d.massage}</span></div>`;
  // time
  document.getElementById('btClock').textContent=(m.time||'').split(' ')[0]||'—';
  document.getElementById('btTxt').innerHTML=`所屬经络：${m.name||'—'}<br>最佳养护：<b>${m.time||'—'}</b>`;
  // foods
  const fd = document.getElementById('detailFoods');
  fd.innerHTML=d.foods.map(f=>`<div class="food"><span class="fdot"></span>${f}</div>`).join('');
}

/* ══════════════════════════════════════════════
   TOOLTIP
══════════════════════════════════════════════ */
function showTip(x,y,name,sub){
  const t=document.getElementById('bodyTip');
  document.getElementById('tipName').textContent=name;
  document.getElementById('tipSub').textContent=sub;
  t.style.left=(x+14)+'px'; t.style.top=(y-10)+'px';
  t.classList.add('show');
}
function hideTip(){ document.getElementById('bodyTip').classList.remove('show'); }

/* ══════════════════════════════════════════════
   MERIDIAN LIST BUILD
══════════════════════════════════════════════ */
function initList(){
  const el = document.getElementById('meridianList');
  el.innerHTML = Object.entries(MERIDIANS).map(([k,d])=>`
    <div class="mitem on" id="ml-${k}" data-mid="${k}" style="--m-c:${d.color}">
      <span class="mbar" style="background:${d.color}"></span>
      <div class="minfo">
        <div class="mname">${d.name}</div>
        <div class="msub">${d.organ} · ${d.time.split('(')[1]?.replace(')','')??d.time}</div>
      </div>
      <span class="mtog"></span>
    </div>
  `).join('');
  // click handlers
  document.querySelectorAll('.mitem').forEach(item=>{
    item.addEventListener('click', e=>{
      e.stopPropagation();
      const mk = item.dataset.mid;
      if(selMid===mk){ selMid=null; clearHighlight(); showEmpty(); item.classList.remove('selected'); return; }
      selMid=mk; selPt=null;
      document.querySelectorAll('.mitem').forEach(i=>i.classList.remove('selected'));
      item.classList.add('selected');
      applyHighlight();
      showMeridianDetail(mk);
    });
  });
}

/* ══════════════════════════════════════════════
   LEGEND BUILD
══════════════════════════════════════════════ */
function initLegend(){
  const el = document.getElementById('legend');
  el.innerHTML = Object.entries(MERIDIANS).map(([k,d])=>`
    <div class="leg-i">
      <span class="leg-l" style="background:${d.color}"></span>
      <span>${d.organ}</span>
    </div>
  `).join('');
}

/* ══════════════════════════════════════════════
   KNOWLEDGE GRID
══════════════════════════════════════════════ */
function initGrid(){
  const el = document.getElementById('knowGrid');
  el.innerHTML = Object.entries(MERIDIANS).map(([k,d])=>`
    <div class="kcard" style="--kc:${d.color}" onclick="document.getElementById('atlas').scrollIntoView({behavior:'smooth'})">
      <div class="kc-icon">${d.organ}</div>
      <div class="kc-name">${d.name}</div>
      <div class="kc-org">${d.organ} · ${d.time}</div>
      <div class="kc-desc">${d.func.substring(0,60)}…</div>
    </div>
  `).join('');
}

/* ══════════════════════════════════════════════
   MERIDIAN PATH CLICK / HOVER
══════════════════════════════════════════════ */
document.querySelectorAll('.mp').forEach(path=>{
  path.addEventListener('click', e=>{
    e.stopPropagation();
    const mk = path.dataset.mid;
    if(!mk) return;
    if(selMid===mk){ selMid=null; clearHighlight(); showEmpty();
      document.querySelectorAll('.mitem').forEach(i=>i.classList.remove('selected')); return; }
    selMid=mk; selPt=null;
    document.querySelectorAll('.mitem').forEach(i=>i.classList.remove('selected'));
    const li = document.getElementById('ml-'+mk);
    if(li) li.classList.add('selected');
    applyHighlight();
    showMeridianDetail(mk);
  });
  path.addEventListener('mouseenter', e=>{
    const d = MERIDIANS[path.dataset.mid];
    if(d) showTip(e.clientX, e.clientY, d.name, d.organ+' · '+d.time);
  });
  path.addEventListener('mouseleave', hideTip);
});

/* ══════════════════════════════════════════════
   ACUPOINT CLICK / HOVER
══════════════════════════════════════════════ */
document.querySelectorAll('.ap').forEach(pt=>{
  pt.addEventListener('click', e=>{
    e.stopPropagation();
    const pk = pt.dataset.pt;
    const ap = ACUPOINTS[pk]; if(!ap) return;
    if(selPt===pk){ selPt=null; selMid=null; clearHighlight(); showEmpty();
      document.querySelectorAll('.mitem').forEach(i=>i.classList.remove('selected')); return; }
    selPt=pk; selMid=null;
    document.querySelectorAll('.ap').forEach(a=>a.classList.toggle('sel',a.dataset.pt===pk));
    document.querySelectorAll('.mitem').forEach(el=>el.classList.toggle('selected',el.id==='ml-'+ap.meridian));
    applyHighlight();
    showAcupointDetail(pk);
  });
  pt.addEventListener('mouseenter', e=>{
    const ap = ACUPOINTS[pt.dataset.pt];
    const m = ap ? MERIDIANS[ap.meridian] : null;
    showTip(e.clientX, e.clientY, pt.dataset.name, pt.dataset.pt+(m?' · '+m.name:''));
  });
  pt.addEventListener('mouseleave', hideTip);
});

/* ══════════════════════════════════════════════
   BACKGROUND CLICK => DESELECT
══════════════════════════════════════════════ */
document.getElementById('bodyCanvas').addEventListener('click', e=>{
  if(e.target===e.currentTarget||e.target.closest('#outlineFront')||e.target.closest('#outlineBack')){
    selMid=null; selPt=null; clearHighlight(); showEmpty();
    document.querySelectorAll('.mitem').forEach(e=>e.classList.remove('selected'));
  }
});

/* ══════════════════════════════════════════════
   BOOT
══════════════════════════════════════════════ */
initList();
initLegend();
initGrid();
switchView('front');
</script>
</body>
</html>
