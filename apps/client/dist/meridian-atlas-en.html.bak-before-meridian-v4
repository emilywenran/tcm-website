  GB34:{ name:'Yanglingquan', loc:'Below the outer knee near the fibular head', func:'Influential point for tendons; soothes liver-gallbladder', massage:'Press to a comfortable ache for 2–3 minutes', foods:['capillaris','lysimachia','bupleurum','dandelion'], meridian:'gallbladder'},
  GB44:{ name:'Zuqiaoyin', loc:'Lateral side of the 4th toe nail corner', func:'Clears heat and eases rib-side, sleep, and head discomfort', massage:'Use brief nail pressure for strong stimulation only if comfortable', foods:['rose tea','finger citron','citron','mint'], meridian:'gallbladder'},
  LR3:{ name:'Taichong', loc:'On the top of the foot between the 1st and 2nd metatarsals', func:'Classic point for moving liver qi and easing emotional constraint', massage:'Slide up from the toe web and press the hollow for 30–60 seconds', foods:['rose tea','chrysanthemum','green tangerine peel','bupleurum'], meridian:'liver'},
  LR8:{ name:'Ququan', loc:'At the medial end of the knee crease', func:'Clears damp-heat and supports lower-jiao regulation', massage:'Bend knee and press the inner hollow for 2 minutes', foods:['coix seed','poria','alisma','plantain herb'], meridian:'liver'},
  LR14:{ name:'Qimen', loc:'In the 6th intercostal space, lateral to the midline', func:'Liver front-mu point; helps move rib-side constraint', massage:'Lie down, press gently with slow breathing', foods:['rose','silk tree flower','finger citron','aged tangerine peel'], meridian:'liver'}
};

/* ══════════════════════════════════════════════
   STATE
══════════════════════════════════════════════ */
let currentView = 'front';  // 'front' | 'back'
let showMer = true;
let showAcu = true;
let selMid = null;
let selPt  = null;

/* ══════════════════════════════════════════════
   VIEW SWITCH — front / back
══════════════════════════════════════════════ */
function switchView(v){
  currentView = v;
  // outline
  document.getElementById('outlineFront').style.display = v==='front'?'':'none';
  document.getElementById('outlineBack').style.display  = v==='back' ?'':'none';
  // toggle buttons
  document.querySelectorAll('#viewToggle button').forEach((b,i)=>{
    b.classList.toggle('active',(i===0&&v==='front')||(i===1&&v==='back'));
  });
  // meridian paths: show paths matching current view OR 'both'
  document.querySelectorAll('.mp').forEach(p=>{
    const pv = p.dataset.view||'front';
    p.style.display = (pv==='both'||pv===v)?'':'none';
  });
  // acupoints: show only matching view
  document.querySelectorAll('.ap').forEach(a=>{
    const av = a.dataset.view||'front';
    const visible = av === v;
    // also hide if showAcu is off
    a.style.display = (visible && showAcu) ? '' : 'none';
  });
  // reapply dim/highlight
  applyHighlight();
}

/* ══════════════════════════════════════════════
   LAYER TOGGLES
══════════════════════════════════════════════ */
function toggleLayer(layer){
  if(layer==='mer'){
    showMer = !showMer;
    document.getElementById('lbtn-mer').classList.toggle('on', showMer);
    document.getElementById('meridianLayer').style.display = showMer?'':'none';
  } else {
    showAcu = !showAcu;
    document.getElementById('lbtn-acu').classList.toggle('on', showAcu);
    // hide/show only current-view points
    document.querySelectorAll('.ap').forEach(a=>{
      const av = a.dataset.view||'front';
      a.style.display = (showAcu && av===currentView)?'':'none';
    });
  }
}

/* ══════════════════════════════════════════════
   HIGHLIGHT
══════════════════════════════════════════════ */
function applyHighlight(){
  const allPaths = document.querySelectorAll('.mp');
  const allAp    = document.querySelectorAll('.ap');
  if(!selMid && !selPt){
    allPaths.forEach(p=>p.classList.remove('dim','hi'));
    allAp.forEach(a=>a.classList.remove('dim','sel'));
    return;
  }
  // dim all visible paths
  allPaths.forEach(p=>{
    const pv = p.dataset.view||'front';
    if(pv!=='both'&&pv!==currentView) return;
    if(selMid){
      p.classList.toggle('dim', p.dataset.mid !== selMid);
      p.classList.toggle('hi',  p.dataset.mid === selMid);
    } else {
      // point selected — highlight that meridian only
      const ap = ACUPOINTS[selPt];
      const mid = ap ? ap.meridian : null;
      p.classList.toggle('dim', p.dataset.mid !== mid);
      p.classList.toggle('hi',  p.dataset.mid === mid);
    }
  });
  // dim all visible ap
  allAp.forEach(a=>{
    const av = a.dataset.view||'front';
    if(av!==currentView) return;
    if(selMid){
      a.classList.toggle('dim', a.dataset.mid !== selMid);
      a.classList.remove('sel');
    } else {
      a.classList.remove('dim');
      a.classList.toggle('sel', a.dataset.pt === selPt);
    }
  });
}

function clearHighlight(){
  document.querySelectorAll('.mp').forEach(p=>p.classList.remove('dim','hi'));
  document.querySelectorAll('.ap').forEach(a=>a.classList.remove('dim','sel'));
}

/* ══════════════════════════════════════════════
   DETAIL PANEL
══════════════════════════════════════════════ */
function showEmpty(){
  document.getElementById('detailEmpty').style.display='flex';
  document.getElementById('detailPanel').classList.remove('show');
}

function showMeridianDetail(mid){
  const d = MERIDIANS[mid]; if(!d) return;
  document.getElementById('detailEmpty').style.display='none';
  const panel = document.getElementById('detailPanel');
  panel.classList.add('show');
  document.getElementById('detailBadge').className='r-badge mer';
  document.getElementById('detailBadge').textContent='Meridian';
  document.getElementById('detailName').textContent=d.name;
  document.getElementById('detailNameEn').textContent=d.en;
  document.getElementById('detailCbar').style.background=d.color;
  document.getElementById('lblFunc').textContent='Main Function';
  document.getElementById('detailFunc').textContent=d.func;
  // symptoms
  const st = document.getElementById('detailSymptoms');
  st.innerHTML=d.symptoms.map(s=>`<span class="tag warn">${s}</span>`).join('');
  // massage
  const ms = document.getElementById('detailMassage');
  ms.innerHTML=d.massage.map((m,i)=>`<div class="step"><span class="snum">${i+1}</span><span>${m}</span></div>`).join('');
  // time
  document.getElementById('btClock').textContent=d.time.split(' ')[0];
  document.getElementById('btTxt').innerHTML=`Best care time<br><b>${d.time}</b>`;
  // foods
  const fd = document.getElementById('detailFoods');
  fd.innerHTML=d.foods.map(f=>`<div class="food"><span class="fdot"></span>${f}</div>`).join('');
}

function showAcupointDetail(pk){
  const d = ACUPOINTS[pk]; if(!d) return;
  const m = MERIDIANS[d.meridian]||{};
  document.getElementById('detailEmpty').style.display='none';
  const panel = document.getElementById('detailPanel');
  panel.classList.add('show');
  document.getElementById('detailBadge').className='r-badge acu';
  document.getElementById('detailBadge').textContent='Acupoint · '+pk;
  document.getElementById('detailName').textContent=d.name;
  document.getElementById('detailNameEn').textContent=(m.name||'')+' · '+d.loc;
  document.getElementById('detailCbar').style.background=m.color||'#C94040';
  document.getElementById('lblFunc').textContent='Main Use';
  document.getElementById('detailFunc').textContent=d.func;
  // symptoms — show meridian symptoms as context
  const st = document.getElementById('detailSymptoms');
  const msyms = m.symptoms||[];
  st.innerHTML=`<span class="tag">Location: ${d.loc}</span>`+msyms.slice(0,4).map(s=>`<span class="tag warn">${s}</span>`).join('');
  // massage
  const ms = document.getElementById('detailMassage');
  ms.innerHTML=`<div class="step"><span class="snum">✦</span><span>${d.massage}</span></div>`;
  // time
  document.getElementById('btClock').textContent=(m.time||'').split(' ')[0]||'—';
  document.getElementById('btTxt').innerHTML=`Channel: ${m.name||'—'}<br>Best care time: <b>${m.time||'—'}</b>`;
  // foods
  const fd = document.getElementById('detailFoods');
  fd.innerHTML=d.foods.map(f=>`<div class="food"><span class="fdot"></span>${f}</div>`).join('');
}

/* ══════════════════════════════════════════════
   TOOLTIP
══════════════════════════════════════════════ */
function showTip(x,y,name,sub){
  const t=document.getElementById('bodyTip');
  document.getElementById('tipName').textContent=name;
  document.getElementById('tipSub').textContent=sub;
  t.style.left=(x+14)+'px'; t.style.top=(y-10)+'px';
  t.classList.add('show');
}
function hideTip(){ document.getElementById('bodyTip').classList.remove('show'); }

/* ══════════════════════════════════════════════
   MERIDIAN LIST BUILD
══════════════════════════════════════════════ */
function initList(){
  const el = document.getElementById('meridianList');
  el.innerHTML = Object.entries(MERIDIANS).map(([k,d])=>`
    <div class="mitem on" id="ml-${k}" data-mid="${k}" style="--m-c:${d.color}">
      <span class="mbar" style="background:${d.color}"></span>
      <div class="minfo">
        <div class="mname">${d.name}</div>
        <div class="msub">${d.organ} · ${d.time}</div>
      </div>
      <span class="mtog"></span>
    </div>
  `).join('');
  // click handlers
  document.querySelectorAll('.mitem').forEach(item=>{
    item.addEventListener('click', e=>{
      e.stopPropagation();
      const mk = item.dataset.mid;
      if(selMid===mk){ selMid=null; clearHighlight(); showEmpty(); item.classList.remove('selected'); return; }
      selMid=mk; selPt=null;
      document.querySelectorAll('.mitem').forEach(i=>i.classList.remove('selected'));
      item.classList.add('selected');
      applyHighlight();
      showMeridianDetail(mk);
    });
  });
}

/* ══════════════════════════════════════════════
   LEGEND BUILD
══════════════════════════════════════════════ */
function initLegend(){
  const el = document.getElementById('legend');
  el.innerHTML = Object.entries(MERIDIANS).map(([k,d])=>`
    <div class="leg-i">
      <span class="leg-l" style="background:${d.color}"></span>
      <span>${d.organ}</span>
    </div>
  `).join('');
}

/* ══════════════════════════════════════════════
   KNOWLEDGE GRID
══════════════════════════════════════════════ */
function initGrid(){
  const el = document.getElementById('knowGrid');
  el.innerHTML = Object.entries(MERIDIANS).map(([k,d])=>`
    <div class="kcard" style="--kc:${d.color}" onclick="document.getElementById('atlas').scrollIntoView({behavior:'smooth'})">
      <div class="kc-icon">${d.organ}</div>
      <div class="kc-name">${d.name}</div>
      <div class="kc-org">${d.organ} · ${d.time}</div>
      <div class="kc-desc">${d.func.substring(0,60)}…</div>
    </div>
  `).join('');
}

/* ══════════════════════════════════════════════
   MERIDIAN PATH CLICK / HOVER
══════════════════════════════════════════════ */
document.querySelectorAll('.mp').forEach(path=>{
  path.addEventListener('click', e=>{
    e.stopPropagation();
    const mk = path.dataset.mid;
    if(!mk) return;
    if(selMid===mk){ selMid=null; clearHighlight(); showEmpty();
      document.querySelectorAll('.mitem').forEach(i=>i.classList.remove('selected')); return; }
    selMid=mk; selPt=null;
    document.querySelectorAll('.mitem').forEach(i=>i.classList.remove('selected'));
    const li = document.getElementById('ml-'+mk);
    if(li) li.classList.add('selected');
    applyHighlight();
    showMeridianDetail(mk);
  });
  path.addEventListener('mouseenter', e=>{
    const d = MERIDIANS[path.dataset.mid];
    if(d) showTip(e.clientX, e.clientY, d.name, d.organ+' · '+d.time);
  });
  path.addEventListener('mouseleave', hideTip);
});

/* ══════════════════════════════════════════════
   ACUPOINT CLICK / HOVER
══════════════════════════════════════════════ */
document.querySelectorAll('.ap').forEach(pt=>{
  pt.addEventListener('click', e=>{
    e.stopPropagation();
    const pk = pt.dataset.pt;
    const ap = ACUPOINTS[pk]; if(!ap) return;
    if(selPt===pk){ selPt=null; selMid=null; clearHighlight(); showEmpty();
      document.querySelectorAll('.mitem').forEach(i=>i.classList.remove('selected')); return; }
    selPt=pk; selMid=null;
    document.querySelectorAll('.ap').forEach(a=>a.classList.toggle('sel',a.dataset.pt===pk));
    document.querySelectorAll('.mitem').forEach(el=>el.classList.toggle('selected',el.id==='ml-'+ap.meridian));
    applyHighlight();
    showAcupointDetail(pk);
  });
  pt.addEventListener('mouseenter', e=>{
    const ap = ACUPOINTS[pt.dataset.pt];
    const m = ap ? MERIDIANS[ap.meridian] : null;
    showTip(e.clientX, e.clientY, pt.dataset.name, pt.dataset.pt+(m?' · '+m.name:''));
  });
  pt.addEventListener('mouseleave', hideTip);
});

/* ══════════════════════════════════════════════
   BACKGROUND CLICK => DESELECT
══════════════════════════════════════════════ */
document.getElementById('bodyCanvas').addEventListener('click', e=>{
  if(e.target===e.currentTarget||e.target.closest('#outlineFront')||e.target.closest('#outlineBack')){
    selMid=null; selPt=null; clearHighlight(); showEmpty();
    document.querySelectorAll('.mitem').forEach(e=>e.classList.remove('selected'));
  }
});

/* ══════════════════════════════════════════════
   BOOT
══════════════════════════════════════════════ */
initList();
initLegend();
initGrid();
switchView('front');
</script>
