<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Meridian Atlas · HERBA & SOUL</title>
<style>
:root{
  --bg:#F5F0E8;--surface:#EDE8DC;--surface2:#E5DDD0;
  --ink:#1A1A1E;--ink2:#3A3830;--ink3:#6B6558;
  --primary:#3D5A7A;--accent:#C94040;--gold:#B8943A;
  --border:#C8BFA8;--border2:#D8D0BC;
  --font-d:'ZCOOL XiaoWei','Noto Serif SC',serif;
  --font-b:'Noto Serif SC','Songti SC',serif;
  --font-m:'Inter',sans-serif;
  --sh-card:0 1px 4px rgba(26,26,30,.07);
  --sh-panel:0 8px 32px rgba(26,26,30,.16);
  --r-sm:4px;--r-md:8px;--r-lg:16px;
  /* 12 meridian colours */
  --lu:#5B8C6A;--li:#8B5530;--st:#C8952A;--sp:#C94040;
  --ht:#A03050;--si:#3D5A7A;--bl:#4A7A5A;--ki:#7B5C8C;
  --pc:#B84060;--tw:#B87040;--gb:#7A4A7A;--lr:#4A6A3A;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--ink);font-family:var(--font-b);background-image:radial-gradient(circle at 20% 10%, rgba(216,211,204,.35) 0 1px, transparent 1px),radial-gradient(circle at 80% 30%, rgba(216,211,204,.25) 0 1px, transparent 1px);background-size:28px 28px,36px 36px;}

/* HEADER */
.hdr{display:flex;align-items:center;justify-content:space-between;
  padding:0 48px;height:60px;
  background:rgba(245,240,232,.96);backdrop-filter:blur(8px);
  border-bottom:1px solid var(--border2);position:sticky;top:0;z-index:100;
  background-image:url('https://skyagent-artifacts.skywork.ai/router/agent/2026-07-09/prod_agent_019f448f-df15-7f30-97d2-736d3a643b45/asset_e7329f7e23b26ae3_97d9cfed55cd48a5a3db954608d92a57.png');
  background-size:cover;background-position:center top;}
.hdr-logo{display:flex;align-items:center;gap:10px;}
.hdr-seal{width:34px;height:34px;background:var(--accent);border-radius:3px;
  display:flex;align-items:center;justify-content:center;
  color:#fff;font-family:var(--font-d);font-size:14px;letter-spacing:1px;}
.hdr-title{font-family:var(--font-d);font-size:20px;color:var(--ink);letter-spacing:3px;}
.hdr-sub{font-size:10px;color:var(--ink3);letter-spacing:2px;font-family:var(--font-m);}
.hdr-nav{display:flex;gap:28px;align-items:center;}
.hdr-nav a{font-size:13px;color:var(--ink2);text-decoration:none;letter-spacing:2px;font-family:var(--font-b);transition:color .2s;}
.hdr-nav a:hover{color:var(--accent);}
.hdr-badge{padding:3px 10px;border:1px solid var(--accent);border-radius:2px;font-size:11px;color:var(--accent);letter-spacing:2px;font-family:var(--font-m);}

/* MAIN 3-COL */
.main{display:grid;grid-template-columns:240px minmax(360px,1fr) 320px;min-height:760px;overflow:hidden;}

/* LEFT */
.lpanel{background:var(--surface);border-right:1px solid var(--border2);overflow-y:auto;padding:20px 0;}
.lpanel::-webkit-scrollbar{width:3px;}
.lpanel::-webkit-scrollbar-thumb{background:var(--border);}
.sec-hd{padding:0 18px 10px;font-size:10px;color:var(--ink3);letter-spacing:3px;font-family:var(--font-m);display:flex;align-items:center;gap:8px;}
.sec-hd::after{content:'';flex:1;height:1px;background:var(--border2);}

/* View toggle */
.vtoggle{display:flex;margin:0 18px 18px;background:var(--surface2);border-radius:5px;padding:3px;gap:2px;}
.vtoggle button{flex:1;padding:7px 0;border:none;background:transparent;border-radius:3px;
  font-size:13px;color:var(--ink3);cursor:pointer;font-family:var(--font-b);letter-spacing:2px;transition:all .2s;}
.vtoggle button.active{background:var(--bg);color:var(--ink);box-shadow:0 1px 3px rgba(26,26,30,.10);}

/* Layer btns */
.layer-row{display:flex;flex-direction:column;gap:6px;padding:0 18px 18px;}
.lbtn{display:flex;align-items:center;gap:9px;padding:9px 12px;border:1px solid var(--border2);
  background:var(--bg);border-radius:5px;cursor:pointer;transition:all .2s;
  font-family:var(--font-b);font-size:12px;color:var(--ink2);letter-spacing:1px;}
.lbtn.on{background:var(--ink);color:#fff;border-color:var(--ink);}
.lbtn .dot{width:7px;height:7px;border-radius:50%;}
.lbtn.on .dot{background:#fff;}
.lbtn:not(.on) .dot{background:var(--border);}

/* Meridian list */
.mlist{display:flex;flex-direction:column;gap:1px;padding:0 10px 16px;}
.mitem{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:5px;
  cursor:pointer;transition:all .16s;border:1px solid transparent;}
.mitem:hover{background:var(--surface2);}
.mitem.selected{background:var(--bg);border-color:var(--border);box-shadow:var(--sh-card);}
.mbar{width:3px;height:26px;border-radius:2px;flex-shrink:0;}
.minfo{flex:1;min-width:0;}
.mname{font-size:12px;font-family:var(--font-d);color:var(--ink);letter-spacing:1px;line-height:1.4;}
.msub{font-size:10px;color:var(--ink3);letter-spacing:1px;font-family:var(--font-m);}
.mtog{width:16px;height:9px;background:var(--border);border-radius:5px;position:relative;flex-shrink:0;transition:background .2s;}
.mtog::after{content:'';position:absolute;left:1px;top:.5px;width:8px;height:8px;border-radius:50%;background:#fff;transition:transform .2s;}
.mitem.on .mtog{background:var(--m-c,var(--primary));}
.mitem.on .mtog::after{transform:translateX(7px);}

/* CENTER */
.cpanel{display:flex;flex-direction:column;align-items:center;overflow-y:auto;
  padding:16px 8px 24px;background:var(--bg);}
.cpanel::-webkit-scrollbar{width:3px;}
.cpanel::-webkit-scrollbar-thumb{background:var(--border);}
.canvas-wrap{position:relative;width:360px;flex-shrink:0;}
.canvas-wrap svg{width:100%;height:auto;display:block;}
.body-tip{position:fixed;background:rgba(245,240,232,.98);border:1px solid var(--border);
  border-radius:7px;padding:9px 13px;max-width:170px;box-shadow:var(--sh-panel);
  font-size:11px;pointer-events:none;z-index:200;display:none;}
.body-tip.show{display:block;}
.tip-name{font-family:var(--font-d);font-size:13px;color:var(--ink);margin-bottom:3px;letter-spacing:1px;}
.tip-sub{font-size:10px;color:var(--ink3);letter-spacing:1px;}
.c-intro{text-align:center;padding:0 0 14px;}
.c-intro-t{font-family:var(--font-d);font-size:14px;color:var(--ink2);letter-spacing:4px;margin-bottom:3px;}
.c-intro-s{font-size:10px;color:var(--ink3);letter-spacing:2px;font-family:var(--font-m);}
.hint-pill{display:flex;align-items:center;gap:5px;padding:6px 13px;background:var(--surface);
  border:1px solid var(--border2);border-radius:20px;font-size:10px;color:var(--ink3);letter-spacing:1px;margin-top:10px;}
.pulse{width:5px;height:5px;border-radius:50%;background:var(--accent);flex-shrink:0;
  animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.5;transform:scale(1.4);}}
.legend{display:flex;flex-wrap:wrap;gap:7px;margin-top:14px;justify-content:center;max-width:360px;}
.leg-i{display:flex;align-items:center;gap:4px;font-size:9px;color:var(--ink3);font-family:var(--font-m);}
.leg-l{width:14px;height:2px;border-radius:1px;}

/* Meridian path */
.mp{cursor:pointer;fill:none;stroke-linecap:round;stroke-linejoin:round;transition:stroke-width .2s,opacity .2s;}
.mp:hover{filter:drop-shadow(0 0 3px currentColor);}
.mp.dim{opacity:.12;}
.mp.hi{stroke-width:3.5!important;filter:drop-shadow(0 0 5px currentColor);}

/* Acupoint */
.ap{cursor:pointer;}
.ap circle{transition:r .15s,opacity .2s;}
.ap:hover circle{r:6;}
.ap.dim circle{opacity:.1;}
.ap.sel circle{r:7;filter:drop-shadow(0 0 5px var(--accent));}

/* RIGHT */
.rpanel{border-left:1px solid var(--border2);background:var(--surface);overflow-y:auto;display:flex;flex-direction:column;}
.rpanel::-webkit-scrollbar{width:3px;}
.rpanel::-webkit-scrollbar-thumb{background:var(--border);}
.r-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:36px 24px;text-align:center;gap:14px;}
.r-empty-ring{width:60px;height:60px;border:1.5px solid var(--border);border-radius:50%;
  display:flex;align-items:center;justify-content:center;color:var(--border);}
.r-empty-t{font-family:var(--font-d);font-size:17px;color:var(--ink2);letter-spacing:3px;}
.r-empty-s{font-size:12px;color:var(--ink3);line-height:1.8;letter-spacing:1px;max-width:220px;}
.r-detail{display:none;flex-direction:column;}
.r-detail.show{display:flex;}
.r-dhead{padding:22px 22px 14px;border-bottom:1px solid var(--border2);}
.r-badge{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:2px;
  font-size:9px;font-family:var(--font-m);letter-spacing:2px;margin-bottom:10px;}
.r-badge.mer{background:rgba(61,90,122,.07);color:var(--primary);border:1px solid rgba(61,90,122,.18);}
.r-badge.acu{background:rgba(201,64,64,.07);color:var(--accent);border:1px solid rgba(201,64,64,.18);}
.r-name{font-family:var(--font-d);font-size:24px;color:var(--ink);letter-spacing:3px;margin-bottom:3px;}
.r-name-en{font-family:var(--font-m);font-size:11px;color:var(--ink3);letter-spacing:2px;}
.r-cbar{width:40px;height:3px;border-radius:2px;margin-top:10px;}
.r-body{padding:18px 22px;flex:1;}
.r-sec{margin-bottom:20px;}
.r-sec-t{font-size:9px;color:var(--ink3);letter-spacing:3px;font-family:var(--font-m);text-transform:uppercase;
  display:flex;align-items:center;gap:7px;margin-bottom:8px;}
.r-sec-t::before{content:'';width:3px;height:11px;border-radius:2px;background:currentColor;flex-shrink:0;}
.r-text{font-size:12px;line-height:1.9;color:var(--ink2);letter-spacing:.5px;}
.tags{display:flex;flex-wrap:wrap;gap:5px;margin-top:6px;}
.tag{padding:3px 8px;background:var(--surface2);border:1px solid var(--border2);border-radius:3px;
  font-size:10px;color:var(--ink2);letter-spacing:1px;font-family:var(--font-b);}
.tag.warn{background:rgba(201,64,64,.06);border-color:rgba(201,64,64,.18);color:var(--accent);}
.steps{display:flex;flex-direction:column;gap:7px;margin-top:6px;}
.step{display:flex;align-items:flex-start;gap:9px;font-size:11px;color:var(--ink2);line-height:1.7;letter-spacing:.5px;}
.snum{width:18px;height:18px;background:var(--ink);color:#fff;border-radius:50%;
  display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0;margin-top:2px;font-family:var(--font-m);}
.foods{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-top:6px;}
.food{display:flex;align-items:center;gap:6px;padding:7px 9px;background:var(--bg);
  border:1px solid var(--border2);border-radius:5px;font-size:11px;color:var(--ink2);letter-spacing:1px;}
.fdot{width:5px;height:5px;border-radius:50%;background:var(--gold);flex-shrink:0;}
.best-time{display:flex;align-items:center;gap:9px;padding:9px 12px;background:var(--bg);
  border:1px solid var(--border2);border-radius:5px;margin-top:6px;}
.bt-clock{font-family:var(--font-d);font-size:17px;color:var(--primary);letter-spacing:1px;}
.bt-txt{font-size:11px;color:var(--ink2);line-height:1.6;}

/* KNOWLEDGE SECTION */
.know{background:var(--bg);border-top:1px solid var(--border2);padding:44px 52px;}
.know-t{text-align:center;font-family:var(--font-d);font-size:26px;color:var(--ink);letter-spacing:6px;margin-bottom:6px;}
.know-s{text-align:center;font-size:12px;color:var(--ink3);letter-spacing:2px;margin-bottom:36px;}
.know-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;max-width:1080px;margin:0 auto;}
.kcard{background:var(--surface);border:1px solid var(--border2);border-radius:7px;padding:18px;
  cursor:pointer;transition:all .2s;position:relative;overflow:hidden;}
.kcard::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--kc,var(--border));opacity:.75;}
.kcard:hover{border-color:var(--border);box-shadow:var(--sh-card);transform:translateY(-1px);}
.kc-icon{font-family:var(--font-d);font-size:20px;color:var(--kc);margin-bottom:8px;letter-spacing:2px;}
.kc-name{font-family:var(--font-d);font-size:14px;color:var(--ink);letter-spacing:2px;margin-bottom:3px;}
.kc-org{font-size:10px;color:var(--ink3);letter-spacing:1px;margin-bottom:8px;font-family:var(--font-m);}
.kc-desc{font-size:10px;color:var(--ink2);line-height:1.7;letter-spacing:.5px;}

/* FOOTER */
.footer{background:var(--ink);color:rgba(255,255,255,.45);padding:24px 52px;
  display:flex;align-items:center;justify-content:space-between;font-size:11px;font-family:var(--font-m);letter-spacing:1px;}
.footer-logo{font-family:var(--font-d);font-size:15px;color:rgba(255,255,255,.65);letter-spacing:3px;}
.footer-disc{font-size:9px;color:rgba(255,255,255,.3);max-width:400px;line-height:1.6;text-align:right;}

.page-scroll{overflow-y:auto;height:calc(100vh - 60px);}
.page-scroll::-webkit-scrollbar{width:5px;}
.page-scroll::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}

.atlas-shell{width:100%;min-height:760px;}
@media (max-width: 900px){
  .main{grid-template-columns:1fr;min-height:auto;overflow:visible;}
  .lpanel,.rpanel{border:1px solid var(--border2);max-height:none;}
  .cpanel{order:-1;overflow:visible;}
  .canvas-wrap{width:min(360px,92vw);}
  .know{padding:32px 18px;}
  .know-grid{grid-template-columns:1fr 1fr;}
}
@media (max-width: 560px){.know-grid{grid-template-columns:1fr}.foods{grid-template-columns:1fr}}
</style>
</head>
